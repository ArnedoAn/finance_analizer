# =============================================================================
# FINANCE ANALYZER - CONFIGURATION
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=finance-analyzer
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# SERVER SETTINGS
# =============================================================================
HOST=0.0.0.0
PORT=8000

# =============================================================================
# DATABASE
# =============================================================================
# SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite+aiosqlite:///./data/finance_analyzer.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/finance_analyzer

# =============================================================================
# GOOGLE / GMAIL API (OAuth 2.0)
# =============================================================================
# Download credentials.json from Google Cloud Console
GOOGLE_CREDENTIALS_PATH=./credentials/google_credentials.json
GOOGLE_TOKEN_PATH=./credentials/google_token.json

# Encryption key for storing OAuth tokens (generate with: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# OAuth redirect URI (must match what you configured in Google Cloud Console)
# Development: http://localhost:8000/api/v1/auth/callback
# Production:  https://your-domain.com/api/v1/auth/callback
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# Gmail query filters (comma-separated subjects to search for)
GMAIL_SUBJECT_FILTERS=Factura,Pago,Recibo,Compra,Confirmación,Transferencia,Cargo,Abono

# Maximum emails to process per batch
GMAIL_MAX_RESULTS=50

# =============================================================================
# DEEPSEEK AI
# =============================================================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3

# =============================================================================
# FIREFLY III
# =============================================================================
FIREFLY_BASE_URL=http://localhost:8080
FIREFLY_API_TOKEN=your-firefly-api-token-here
FIREFLY_TIMEOUT=30
FIREFLY_MAX_RETRIES=3

# Default accounts (will be created if not exist)
FIREFLY_DEFAULT_ASSET_ACCOUNT=Cuenta Principal
FIREFLY_DEFAULT_EXPENSE_ACCOUNT=Gastos Generales
FIREFLY_DEFAULT_REVENUE_ACCOUNT=Ingresos Generales

# =============================================================================
# CURRENCY
# =============================================================================
# Default currency code (ISO 4217)
DEFAULT_CURRENCY=COP

# =============================================================================
# PROCESSING OPTIONS
# =============================================================================
# Enable dry-run mode (analyze but don't create transactions)
DRY_RUN=false

# Enable automatic account creation
AUTO_CREATE_ACCOUNTS=true

# Enable automatic category creation
AUTO_CREATE_CATEGORIES=true

# Number of days to look back for emails
EMAIL_LOOKBACK_DAYS=7

# =============================================================================
# RETRY CONFIGURATION
# =============================================================================
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=2
RETRY_MAX_WAIT_SECONDS=30

# =============================================================================
# SCHEDULER CONFIGURATION (CRON)
# =============================================================================
# Enable/disable scheduled tasks
SCHEDULER_ENABLED=true

# Email processing schedule (default: every 6 hours)
SCHEDULER_PROCESSING_CRON=0 */6 * * *

# Sender learning schedule (default: 1st and 15th of each month at midnight)
SCHEDULER_LEARNING_CRON=0 0 1,15 * *

# Number of emails to analyze for learning
SCHEDULER_LEARNING_EMAIL_COUNT=100

# =============================================================================
# TOKEN OPTIMIZATION (DeepSeek)
# =============================================================================
# Maximum characters to send to AI (reduces token usage)
DEEPSEEK_MAX_EMAIL_CHARS=2000

# Strip HTML tags from emails before sending to AI
DEEPSEEK_STRIP_HTML=true

# Strip email signatures
DEEPSEEK_STRIP_SIGNATURES=true

# Strip legal/marketing footers
DEEPSEEK_STRIP_FOOTERS=true
