# =============================================================================
# Finance Analyzer - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
#
# Usage: cp env.production.example .env
#        nano .env

# -----------------------------------------------------------------------------
# Docker Registry Configuration
# -----------------------------------------------------------------------------
REGISTRY_URL=your-registry.com
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO
PORT=8000
# Seed/fallback session; scheduler runs all discovered active sessions.
SCHEDULER_DEFAULT_SESSION_ID=default
SESSION_COOKIE_MAX_AGE_SECONDS=2592000
OAUTH_STATE_MAX_AGE_SECONDS=600

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_USER=finance_analyzer
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=finance_analyzer
POSTGRES_PORT=5432

# Database URL (automatically constructed from above in docker-compose, or set manually)
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL=postgresql+asyncpg://finance_analyzer:password@postgres:5432/finance_analyzer

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate a strong 32+ character key for token encryption
# You can use: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=your-32-character-encryption-key-here

# -----------------------------------------------------------------------------
# DeepSeek AI
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=60
DEEPSEEK_MAX_RETRIES=3
DEEPSEEK_MAX_EMAIL_CHARS=2000
DEEPSEEK_STRIP_HTML=true
DEEPSEEK_STRIP_SIGNATURES=true
DEEPSEEK_STRIP_FOOTERS=true

# -----------------------------------------------------------------------------
# Firefly III
# -----------------------------------------------------------------------------
FIREFLY_BASE_URL=https://your-firefly-instance.com
FIREFLY_API_TOKEN=your-firefly-api-token
FIREFLY_TOKEN_PATH=./credentials/firefly_token.json
FIREFLY_TIMEOUT=30
FIREFLY_MAX_RETRIES=3
FIREFLY_DEFAULT_ASSET_ACCOUNT=Bancolombia
FIREFLY_DEFAULT_EXPENSE_ACCOUNT=Gastos Generales
FIREFLY_DEFAULT_REVENUE_ACCOUNT=Ingresos Generales

# -----------------------------------------------------------------------------
# Gmail OAuth
# -----------------------------------------------------------------------------
# IMPORTANT: Update this to match your production domain
# Must match the redirect URI configured in Google Cloud Console
GMAIL_REDIRECT_URI=https://your-domain.com/api/v1/auth/callback
GMAIL_SUBJECT_FILTERS=Factura,Pago,Recibo,Compra,Confirmación,Transferencia,Cargo,Abono
GMAIL_MAX_RESULTS=50

# Paths to credentials (relative to container /app directory)
# These files should be mounted as volumes in docker-compose
GOOGLE_CREDENTIALS_PATH=./credentials/google_credentials.json
GOOGLE_TOKEN_PATH=./credentials/google_token.json

# -----------------------------------------------------------------------------
# Processing Configuration
# -----------------------------------------------------------------------------
DRY_RUN=false
AUTO_CREATE_ACCOUNTS=true
AUTO_CREATE_CATEGORIES=true
DEFAULT_CURRENCY=COP
EMAIL_LOOKBACK_DAYS=7

# -----------------------------------------------------------------------------
# Scheduler Configuration
# -----------------------------------------------------------------------------
SCHEDULER_ENABLED=true
SCHEDULER_PROCESSING_CRON=0 */6 * * *
SCHEDULER_LEARNING_CRON=0 0 1,15 * *
SCHEDULER_LEARNING_EMAIL_COUNT=100

# -----------------------------------------------------------------------------
# Retry Configuration
# -----------------------------------------------------------------------------
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_SECONDS=2
RETRY_MAX_WAIT_SECONDS=30

# -----------------------------------------------------------------------------
# Test Mode (MUST be false in production)
# -----------------------------------------------------------------------------
TEST_MODE_CLEAR_PROCESSED=false

